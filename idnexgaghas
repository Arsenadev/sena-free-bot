</div>
<script>
  let cur = 1;
  const total = 4;

  document.querySelectorAll('input[name="jml"]').forEach(r => {
    r.addEventListener('change', function() {
      const n = parseInt(this.value);
      for (let i = 1; i <= 3; i++) {
        document.getElementById('lw'+i).style.display = i <= n ? 'block' : 'none';
        if (i > n) document.getElementById('lg'+i).value = '';
      }
    });
  });

  function getLinks() {
    const n = parseInt(document.querySelector('input[name="jml"]:checked').value);
    return Array.from({length:n}, (_,i) => document.getElementById('lg'+(i+1)).value.trim());
  }

  function goStep(n) {
    if (n > 1 && cur === 1) {
      const nama = document.getElementById('namaUser').value.trim();
      if (!nama) { alert('⚠ Masukkan nama kamu dulu!'); return; }
      const links = getLinks();
      for (let i = 0; i < links.length; i++) {
        if (!links[i]) { alert(`⚠ Link Grup ${i+1} belum diisi!`); return; }
        if (!links[i].startsWith('https://chat.whatsapp.com/')) {
          alert(`⚠ Link Grup ${i+1} harus diawali https://chat.whatsapp.com/`); return;
        }
      }
    }

    document.getElementById('step'+cur).classList.remove('active');
    document.getElementById('step'+cur).style.display = 'none';
    cur = n;
    const el = document.getElementById('step'+n);
    el.style.display = 'block';
    el.classList.add('active');

    for (let i = 1; i <= total; i++) {
      const s = document.getElementById('st'+i);
      s.classList.remove('active','done');
      if (i < n) s.classList.add('done');
      else if (i === n) s.classList.add('active');
    }
    for (let i = 1; i < total; i++) {
      const l = document.getElementById('ln'+i);
      if (l) l.classList.toggle('done', i < n);
    }

