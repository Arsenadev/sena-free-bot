<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sena Free Bot</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}

:root{
  --bg:#080c14;
  --panel:#0d1320;
  --border:rgba(99,179,237,.14);
  --border2:rgba(99,179,237,.32);
  --accent:#63b3ed;
  --accent2:#90cdf4;
  --glow:rgba(99,179,237,.4);
  --text:#e2eaf4;
  --muted:#4a6080;
  --red:#fc8181;
  --yellow:#f6e05e;
  --green:#68d391;
}

body{
  background:var(--bg);
  color:var(--text);
  font-family:'Rajdhani',sans-serif;
  min-height:100vh;
  overflow-x:hidden;
}

body::after{
  content:'';
  position:fixed;inset:0;
  background-image:radial-gradient(rgba(99,179,237,.09) 1px,transparent 1px);
  background-size:28px 28px;
  pointer-events:none;z-index:0;
}

.page{
  position:relative;z-index:1;
  max-width:620px;margin:0 auto;
  padding:0 16px 80px;
}

/* ── HEADER ── */
.site-header{
  padding:52px 0 36px;
  text-align:center;
  border-bottom:1px solid var(--border2);
  margin-bottom:0;
  position:relative;
}

.site-header::after{
  content:'';
  position:absolute;bottom:-1px;left:50%;
  transform:translateX(-50%);
  width:60px;height:2px;
  background:var(--accent);
  box-shadow:0 0 12px var(--glow);
}

.badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(99,179,237,.06);
  border:1px solid var(--border2);
  padding:4px 14px;border-radius:99px;
  font-family:'Share Tech Mono',monospace;
  font-size:10px;letter-spacing:3px;color:var(--muted);
  text-transform:uppercase;margin-bottom:22px;
}

.badge-dot{
  width:5px;height:5px;border-radius:50%;
  background:var(--green);box-shadow:0 0 6px var(--green);
  animation:pulse 2s ease-in-out infinite;
}

@keyframes pulse{0%,100%{opacity:1}50%{opacity:.2}}

.site-title{
  font-family:'Orbitron',monospace;
  font-weight:900;
  font-size:clamp(30px,9vw,58px);
  letter-spacing:4px;
  line-height:1;
  color:#fff;
  white-space:nowrap;
}

.site-title .ac{
  color:var(--accent);
  text-shadow:0 0 22px var(--glow),0 0 50px rgba(99,179,237,.2);
}

.site-sub{
  font-family:'Share Tech Mono',monospace;
  font-size:11px;color:var(--muted);
  letter-spacing:3px;margin-top:12px;
}

/* ── TICKER ── */
.ticker-wrap{
  overflow:hidden;
  border-bottom:1px solid var(--border);
  padding:9px 0;margin-bottom:32px;
  background:rgba(99,179,237,.02);
}

.ticker-track{
  display:inline-flex;gap:48px;
  animation:scroll 22s linear infinite;
  white-space:nowrap;
}

.ticker-track span{
  font-family:'Share Tech Mono',monospace;
  font-size:10px;letter-spacing:2px;
  color:var(--muted);text-transform:uppercase;
}

@keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ── STEPPER ── */
.stepper{
  display:flex;align-items:flex-start;
  justify-content:center;
  margin-bottom:24px;
}

.st{
  display:flex;flex-direction:column;
  align-items:center;gap:5px;min-width:52px;
}

.st-c{
  width:30px;height:30px;border-radius:50%;
  border:1.5px solid var(--border2);
  display:flex;align-items:center;justify-content:center;
  font-family:'Share Tech Mono',monospace;font-size:10px;
  color:var(--muted);transition:all .25s;
}

.st.active .st-c{
  border-color:var(--accent);color:var(--accent);
  background:rgba(99,179,237,.1);
  box-shadow:0 0 0 3px rgba(99,179,237,.12);
}

.st.done .st-c{border-color:var(--green);background:var(--green);color:var(--bg);}

.st-lbl{
  font-family:'Share Tech Mono',monospace;
  font-size:9px;letter-spacing:1px;
  color:var(--muted);text-transform:uppercase;
}

.st.active .st-lbl{color:var(--accent);}

.st-line{
  flex:1;height:1.5px;background:var(--border);
  margin-bottom:18px;min-width:20px;max-width:44px;
  transition:background .25s;
}
.st-line.done{background:var(--green);}

.prog-bar{height:2px;background:var(--border);border-radius:2px;margin-bottom:28px;overflow:hidden;}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));box-shadow:0 0 8px var(--glow);transition:width .4s ease;}

/* ── CARD ── */
.card{
  display:none;
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:10px;
  padding:22px;
  margin-bottom:16px;
  animation:fadeUp .3s ease;
  position:relative;overflow:hidden;
}

.card::before{
  content:'';position:absolute;
  top:0;left:16px;right:16px;height:1px;
  background:linear-gradient(90deg,transparent,var(--accent),transparent);
  opacity:.4;
}

.card.active{display:block;}

@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

.card-head{
  display:flex;align-items:center;gap:10px;margin-bottom:20px;
}

.card-icon{
  width:28px;height:28px;
  border:1px solid var(--border2);border-radius:6px;
  display:flex;align-items:center;justify-content:center;
  font-size:13px;flex-shrink:0;
}

.card-title{
  font-family:'Orbitron',monospace;font-size:11px;
  font-weight:700;color:var(--accent2);
  letter-spacing:2px;text-transform:uppercase;
}

/* ── FORM ── */
.field{margin-bottom:16px;}

.flabel{
  display:block;
  font-family:'Share Tech Mono',monospace;
  font-size:10px;letter-spacing:2.5px;
  color:var(--muted);text-transform:uppercase;
  margin-bottom:7px;
}

input[type=text],input[type=url]{
  width:100%;
  background:rgba(99,179,237,.04);
  border:1px solid var(--border2);
  border-radius:7px;
  padding:11px 14px;
  font-family:'Share Tech Mono',monospace;
  font-size:12px;color:var(--text);
  outline:none;
  transition:border-color .2s,box-shadow .2s;
}

input:focus{
  border-color:var(--accent);
  box-shadow:0 0 0 3px rgba(99,179,237,.1);
}
input::placeholder{color:var(--muted);}

/* count pick */
.count-row{display:flex;gap:10px;margin-bottom:18px;}

.count-radio{display:none;}

.count-lbl{
  flex:1;padding:13px 8px;
  border:1px solid var(--border2);border-radius:8px;
  text-align:center;cursor:pointer;
  transition:all .2s;background:rgba(99,179,237,.02);
}
.count-lbl:hover{border-color:var(--accent);background:rgba(99,179,237,.06);}
.count-radio:checked+.count-lbl{
  border-color:var(--accent);background:rgba(99,179,237,.12);
  box-shadow:0 0 0 2px rgba(99,179,237,.15);
}
.count-n{
  font-family:'Orbitron',monospace;font-size:22px;
  font-weight:900;color:var(--accent);
  line-height:1;display:block;
}
.count-t{
  font-family:'Share Tech Mono',monospace;font-size:9px;
  color:var(--muted);letter-spacing:1px;
  text-transform:uppercase;margin-top:4px;display:block;
}

/* alerts */
.alert{
  border-radius:7px;padding:12px 14px;
  margin-bottom:16px;
  font-family:'Share Tech Mono',monospace;
  font-size:11px;line-height:1.75;
}
.alert strong{
  display:block;font-size:11px;
  letter-spacing:1.5px;text-transform:uppercase;margin-bottom:4px;
}
.a-warn{background:rgba(252,129,74,.07);border:1px solid rgba(252,129,74,.3);color:#fba572;}
.a-info{background:rgba(246,224,94,.05);border:1px solid rgba(246,224,94,.25);color:#f6e05e;}
.a-tip {background:rgba(104,211,145,.06);border:1px solid rgba(104,211,145,.25);color:var(--green);}

/* syarat */
.syarat-box{
  background:rgba(0,0,0,.25);
  border:1px solid var(--border2);
  border-radius:7px;overflow:hidden;margin-bottom:16px;
}
.syarat-top{
  display:flex;align-items:center;justify-content:space-between;
  padding:9px 14px;border-bottom:1px solid var(--border);
  background:rgba(99,179,237,.04);
}
.syarat-tag{
  font-family:'Share Tech Mono',monospace;font-size:10px;
  color:var(--muted);letter-spacing:2px;text-transform:uppercase;
}
.copy-btn{
  background:rgba(99,179,237,.1);border:1px solid var(--border2);
  border-radius:4px;color:var(--accent);
  font-family:'Share Tech Mono',monospace;font-size:10px;
  letter-spacing:1px;padding:4px 12px;cursor:pointer;
  transition:all .2s;text-transform:uppercase;
}
.copy-btn:hover{background:rgba(99,179,237,.2);}
.copy-btn.ok{background:rgba(104,211,145,.2);border-color:var(--green);color:var(--green);}

.syarat-body{
  padding:14px;
  font-family:'Share Tech Mono',monospace;
  font-size:12px;color:var(--text);
  line-height:1.85;white-space:pre-wrap;
}

/* follow link */
.follow-link{
  display:flex;align-items:center;gap:14px;
  padding:14px 16px;
  background:rgba(99,179,237,.05);
  border:1px solid var(--accent);border-radius:8px;
  text-decoration:none;transition:background .2s;margin-bottom:18px;
}
.follow-link:hover{background:rgba(99,179,237,.1);}
.follow-av{
  width:38px;height:38px;background:var(--accent);
  border-radius:50%;display:flex;align-items:center;
  justify-content:center;font-size:17px;flex-shrink:0;
}
.follow-info strong{
  display:block;font-family:'Orbitron',monospace;
  font-size:10px;color:var(--accent2);letter-spacing:1px;margin-bottom:3px;
}
.follow-info span{
  font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--muted);
}

/* checklist */
.cl{list-style:none;margin-bottom:16px;}
.cl li{
  display:flex;align-items:flex-start;gap:10px;
  padding:10px 0;border-bottom:1px solid var(--border);
  font-size:14px;font-weight:500;color:var(--text);line-height:1.5;
}
.cl li:last-child{border:none;}
.ci{font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--accent);flex-shrink:0;margin-top:1px;}

/* buttons */
.btn{
  display:block;width:100%;padding:13px 20px;
  border-radius:8px;font-family:'Orbitron',monospace;
  font-size:11px;font-weight:700;letter-spacing:2.5px;
  text-transform:uppercase;cursor:pointer;
  transition:all .2s;text-decoration:none;
  text-align:center;
}
.btn-p{
  background:var(--accent);border:none;color:var(--bg);
  box-shadow:0 4px 20px rgba(99,179,237,.25);
}
.btn-p:hover{background:var(--accent2);box-shadow:0 4px 28px rgba(99,179,237,.4);transform:translateY(-1px);}

.btn-g{
  background:transparent;border:1px solid var(--border2);
  color:var(--muted);margin-top:10px;
}
.btn-g:hover{border-color:var(--accent);color:var(--accent);}

.btn-wa{
  background:#25D366;border:none;color:#fff;
  box-shadow:0 4px 20px rgba(37,211,102,.2);
}
.btn-wa:hover{background:#1fba58;box-shadow:0 4px 28px rgba(37,211,102,.35);transform:translateY(-1px);}

/* final */
.fin{text-align:center;padding:8px 0 16px;}
.fin-emoji{font-size:44px;display:block;margin-bottom:14px;}
.fin-title{
  font-family:'Orbitron',monospace;font-size:18px;
  font-weight:900;color:#fff;margin-bottom:8px;letter-spacing:2px;
}
.fin-sub{
  font-family:'Rajdhani',sans-serif;font-size:15px;
  font-weight:500;color:var(--muted);line-height:1.7;margin-bottom:22px;
}
.fin-sub b{color:var(--accent);}
</style>
</head>
