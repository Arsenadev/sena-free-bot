      <div class="count-row">
        <input type="radio" name="jml" id="g1" value="1" class="count-radio" checked>
        <label class="count-lbl" for="g1"><span class="count-n">1</span><span class="count-t">Grup</span></label>
        <input type="radio" name="jml" id="g2" value="2" class="count-radio">
        <label class="count-lbl" for="g2"><span class="count-n">2</span><span class="count-t">Grup</span></label>
        <input type="radio" name="jml" id="g3" value="3" class="count-radio">
